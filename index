
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font-sans); }
.crm { display: flex; height: 580px; background: var(--color-background-tertiary); border-radius: var(--border-radius-lg); overflow: hidden; border: 0.5px solid var(--color-border-tertiary); }
.sidebar { width: 200px; background: var(--color-background-primary); border-right: 0.5px solid var(--color-border-tertiary); padding: 16px 0; flex-shrink: 0; }
.logo { padding: 0 16px 20px; font-size: 15px; font-weight: 500; color: var(--color-text-primary); border-bottom: 0.5px solid var(--color-border-tertiary); margin-bottom: 8px; }
.logo span { color: #1D9E75; }
.nav-item { display: flex; align-items: center; gap: 10px; padding: 8px 16px; font-size: 13px; color: var(--color-text-secondary); cursor: pointer; transition: background 0.15s; }
.nav-item:hover { background: var(--color-background-secondary); }
.nav-item.active { background: #E1F5EE; color: #0F6E56; font-weight: 500; }
.nav-icon { width: 16px; height: 16px; flex-shrink: 0; }
.nav-badge { margin-left: auto; background: #1D9E75; color: white; font-size: 10px; padding: 1px 6px; border-radius: 10px; }
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.topbar { padding: 12px 20px; background: var(--color-background-primary); border-bottom: 0.5px solid var(--color-border-tertiary); display: flex; align-items: center; gap: 12px; }
.page-title { font-size: 15px; font-weight: 500; color: var(--color-text-primary); flex: 1; }
.google-badge { display: flex; align-items: center; gap: 6px; background: #E6F1FB; border: 0.5px solid #B5D4F4; padding: 5px 10px; border-radius: var(--border-radius-md); font-size: 12px; color: #185FA5; }
.btn-primary { background: #1D9E75; color: white; border: none; padding: 6px 14px; border-radius: var(--border-radius-md); font-size: 13px; cursor: pointer; }
.content { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 14px; }
.metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
.metric { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-md); padding: 12px; }
.metric-label { font-size: 11px; color: var(--color-text-secondary); margin-bottom: 4px; }
.metric-val { font-size: 22px; font-weight: 500; color: var(--color-text-primary); }
.metric-sub { font-size: 11px; color: #1D9E75; margin-top: 2px; }
.panels { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; flex: 1; }
.panel { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-md); overflow: hidden; }
.panel-head { padding: 10px 14px; border-bottom: 0.5px solid var(--color-border-tertiary); display: flex; align-items: center; gap: 8px; }
.panel-title { font-size: 13px; font-weight: 500; color: var(--color-text-primary); flex: 1; }
.panel-action { font-size: 11px; color: #1D9E75; cursor: pointer; }
.contact-row { display: flex; align-items: center; gap: 10px; padding: 8px 14px; border-bottom: 0.5px solid var(--color-border-tertiary); }
.contact-row:last-child { border-bottom: none; }
.avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 500; flex-shrink: 0; }
.av-teal { background: #9FE1CB; color: #085041; }
.av-blue { background: #B5D4F4; color: #0C447C; }
.av-amber { background: #FAC775; color: #633806; }
.av-purple { background: #CECBF6; color: #3C3489; }
.contact-info { flex: 1; min-width: 0; }
.contact-name { font-size: 13px; font-weight: 500; color: var(--color-text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.contact-company { font-size: 11px; color: var(--color-text-secondary); }
.tag { font-size: 10px; padding: 2px 7px; border-radius: 10px; white-space: nowrap; }
.tag-hot { background: #FAECE7; color: #993C1D; }
.tag-warm { background: #FAEEDA; color: #854F0B; }
.tag-cold { background: #E6F1FB; color: #185FA5; }
.tag-new { background: #EAF3DE; color: #3B6D11; }
.deal-row { display: flex; align-items: center; gap: 10px; padding: 8px 14px; border-bottom: 0.5px solid var(--color-border-tertiary); }
.deal-row:last-child { border-bottom: none; }
.deal-name { font-size: 13px; color: var(--color-text-primary); flex: 1; }
.deal-amount { font-size: 13px; font-weight: 500; color: var(--color-text-primary); }
.stage { font-size: 10px; padding: 2px 7px; border-radius: 10px; }
.stage-neg { background: #FAEEDA; color: #854F0B; }
.stage-prop { background: #CECBF6; color: #3C3489; }
.stage-won { background: #9FE1CB; color: #085041; }
.stage-qual { background: #E6F1FB; color: #185FA5; }
.gcal { padding: 10px 14px; }
.cal-event { display: flex; gap: 10px; align-items: flex-start; padding: 7px 0; border-bottom: 0.5px solid var(--color-border-tertiary); }
.cal-event:last-child { border-bottom: none; }
.cal-time { font-size: 11px; color: var(--color-text-secondary); min-width: 50px; }
.cal-dot { width: 8px; height: 8px; border-radius: 50%; margin-top: 3px; flex-shrink: 0; }
.dot-blue { background: #378ADD; }
.dot-teal { background: #1D9E75; }
.dot-amber { background: #BA7517; }
.cal-text { font-size: 12px; color: var(--color-text-primary); line-height: 1.4; }
.cal-sub { font-size: 11px; color: var(--color-text-secondary); }
.g-icon { display: inline-flex; align-items: center; gap: 3px; }
</style>

